EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Copy this file to .env and paste your Mapbox public token (pk....)
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-public-token
# Web app URL for parcel boundary API (defaults to https://mregan.xyz/garden)
EXPO_PUBLIC_GARDEN_WEB_URL=https://mregan.xyz/garden
